{
    "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
    "formatter": { "enabled": true },
    "linter": { "enabled": true, "rules": { "recommended": true } },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "arrowParentheses": "always",
            "trailingCommas": "all",
            "bracketSpacing": true,
            "semicolons": "always",
            "indentWidth": 4
        }
    },
    "json": {
        "formatter": {
            "trailingCommas": "none",
            "indentStyle": "space",
            "indentWidth": 4
        }
    }
}
